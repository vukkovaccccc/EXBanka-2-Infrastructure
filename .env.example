# ============================================================
# EXBanka-2 — Central Environment Configuration
#
# Copy to .env and fill in real values before running:
#   cp .env.example .env
#
# Never commit .env to version control.
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────

POSTGRES_USER=bank_admin
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=bank_db

# Host port PostgreSQL is reachable on from your machine.
DB_EXTERNAL_PORT=5433

# ── RabbitMQ ─────────────────────────────────────────────────
# Default guest credentials are fine for local dev only.
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Backend Service Ports (host-side) ────────────────────────
# user-service HTTP (REST): podrazumevano 8082
USER_SERVICE_HTTP_PORT=8082
USER_SERVICE_GRPC_PORT=50052
# bank-service HTTP (REST + trading /api/bank): podrazumevano 8083
BANK_SERVICE_HTTP_PORT=8083
BANK_SERVICE_GRPC_PORT=50054

# ── JWT (OBA servisa moraju imati isti JWT_ACCESS_SECRET) ─────
# U .env fajlu NE stavljaj razmake oko znaka = (npr. JWT_ACCESS_SECRET=vrednost).
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACTIVATION_SECRET=change_me_activation_secret_min_32_chars

# user-service → bank HTTP (Docker mreža; ne menjaj osim ako menjaš ime servisa)
BANK_SERVICE_ADDR=http://bank-service:8080

# gRPC adresa user-service-a iz bank kontejnera (podrazumevano)
USER_SERVICE_ADDR=user-service:50051

# ── Notification Service / SMTP ──────────────────────────────

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
# For Gmail use an App Password, not your account password.
SMTP_PASS=your-app-password
FROM_EMAIL=no-reply@example.com

# URL the backend embeds in verification / password-reset emails.
FRONTEND_URL=http://localhost:3001
# Host port za frontend nginx (docker compose)
FRONTEND_HTTP_PORT=3001

# ── Frontend Build Args ───────────────────────────────────────
# These are baked into the Vite bundle at image-build time (not runtime).
# VITE_API_BASE_URL=/api routes API calls through the Nginx proxy rule.
VITE_API_BASE_URL=/api
VITE_MOCK_MODE=false
VITE_APP_ENV=development
VITE_ACCESS_TOKEN_TTL_MS=900000

# ── Tržišni podaci za hartije od vrednosti ───────────────────
# EODHD – primarni izvor real-time cena: https://eodhd.com
EODHD_API_KEY=your-eodhd-api-key

# Finnhub – sekundarni izvor (fallback): https://finnhub.io
FINNHUB_API_KEY=your-finnhub-api-key

# Alpha Vantage – Company Overview (STOCK) i Forex rates
ALPHAVANTAGE_API_KEY=your-alphavantage-api-key

# Koliko često (u minutima) worker osvežava cene hartija. Dev: 1, prod: 15
LISTING_REFRESH_INTERVAL_MINUTES=15

# true (podrazumevano u produkciji): nema lažnih/sintetičkih cena — ako eksterni API ne vrati
# validan kurs, red u bazi se ne menja (ostaje poslednji poznat quote). Za lokalni dev bez ključeva: false.
# Zastarelo: LISTING_STRICT_EXTERNAL=true se i dalje tumači kao isto što i REQUIRE_LIVE.
LISTING_REQUIRE_LIVE_QUOTES=true

# Opciono: ID tekućeg RSD računa u core_banking.racun za simulaciju prijema poreza od strane države (0 = isključeno)
STATE_REVENUE_ACCOUNT_ID=0
